# Example .env for Bank Statement Analyzer (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_password
DB_NAME=bank_analyzer
UPLOAD_DIR=./uploads

# Example .env for Bank Statement Analyzer (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_password
DB_NAME=bank_analyzer
UPLOAD_DIR=./uploads

# Security configuration
JWT_SECRET_KEY=generate_a_random_secret_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limits & CORS
RATE_LIMIT_INSIGHTS_PER_MINUTE=1/minute
FRONTEND_ORIGIN=http://localhost:5173

# Database connection (REQUIRED)
DATABASE_URL=sqlite:///./bank_analyzer.db
