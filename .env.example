# ── Backend ─────────────────────────────────────────────────
# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_password
DB_NAME=bank_analyzer

# File uploads
UPLOAD_DIR=./uploads

# OCR (optional — only needed for scanned PDFs)
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# ── Frontend ────────────────────────────────────────────────
# API base URL (used by Vite via import.meta.env)
VITE_API_URL=http://localhost:8000/api/v1
